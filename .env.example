MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=tool_registry
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_CONNECT_TIMEOUT_MS=5000
MONGODB_DEFER_INDEX_CREATION=false
REDIS_URL=redis://localhost:6379/0
REDIS_TOOLS_LIST_TTL_SECONDS=60
RETRY_MAX_ATTEMPTS=3
RETRY_MIN_WAIT_SECONDS=0.5
RETRY_MAX_WAIT_SECONDS=8
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_SECONDS=60
TOOL_EXECUTION_TIMEOUT_SECONDS=30
API_REQUEST_TIMEOUT_SECONDS=15
RATE_LIMIT_PER_MINUTE=60
BULKHEAD_MAX_CONCURRENT_PER_TOOL=10
REDIS_CONNECT_TIMEOUT_SECONDS=5
REDIS_CONNECT_RETRY_ATTEMPTS=3
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
MCP_PATH=/mcp
